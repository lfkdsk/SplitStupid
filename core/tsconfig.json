{
  "compilerOptions": {
    "target": "ES2022",
    // DOM is here only for the structural types of `fetch` / `Headers` /
    // `Response` used by the API client — core never touches `document`
    // or `window`. RN, Node 20, and Workers all provide these at runtime.
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src"]
}
