{
  "expo": {
    "name": "SplitStupid",
    "slug": "splitstupid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "splitstupid",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#faf6ef"
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "org.lfkdsk.splitstupid",
      "buildNumber": "4",
      "associatedDomains": [
        "applinks:splitstupid.lfkdsk.org"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "org.lfkdsk.splitstupid",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "splitstupid.lfkdsk.org",
              "pathPrefix": "/g"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SplitStupid to scan invite QR codes."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "71061add-6fea-47fe-b3b5-d95a4e70e642"
      }
    }
  }
}
