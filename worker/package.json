{
  "name": "splitstupid-data",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:init": "wrangler d1 execute splitstupid --remote --file=migrations/0001_init.sql",
    "db:init:local": "wrangler d1 execute splitstupid --local --file=migrations/0001_init.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "~6.0.2",
    "wrangler": "^4.0.0"
  }
}
