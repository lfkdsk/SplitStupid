# Same OAuth App as the rest of the lfkdsk umbrella — public, safe to check in.
# Leave the OAuth pair unset to disable the GitHub sign-in button (the email
# magic-link form will still show as long as VITE_API_URL is set and the
# Worker has RESEND_API_KEY configured).
VITE_OAUTH_CLIENT_ID=Ov23liCg29llKxJ7b0jv

# Auth broker — exchanges the OAuth code for an access token.
VITE_OAUTH_WORKER_URL=https://auth.lfkdsk.org/splitstupid

# Backend API (Cloudflare Worker + D1). Used for everything ledger-related,
# and also for the magic-link email sign-in flow (POST /auth/magic/request).
VITE_API_URL=https://api.splitstupid.lfkdsk.org
